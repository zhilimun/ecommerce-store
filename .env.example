# Environment Variables for Ecommerce Store

# Public API URL
NEXT_PUBLIC_API_URL=

# Database URL (if using external DB)
DATABASE_URL=

# Stripe Keys (if using Stripe payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Analytics (if using Google Analytics)
NEXT_PUBLIC_GA_ID=

# Other possible environment variables
NEXT_PUBLIC_SITE_URL=http://localhost:3000