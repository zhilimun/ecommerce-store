{
  "version": 2,
  "framework": "nextjs",
  "settings": {
    "nodeVersion": "20.x",
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "devCommand": "npm run dev"
  },
  "functions": {
    "pages/api/**/*.js": {
      "maxDuration": 30
    }
  },
  "regions": ["sfo1"],
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "zeroConfig": true
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}